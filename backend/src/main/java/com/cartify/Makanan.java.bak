package com.cartify;

/**
 *
 * @author HP
 */
public class Makanan extends Product {
    private String tanggalKedaluwarsa;

    // Constructor khusus untuk Makanan
    public Makanan(String id, String namaProduk, double harga, double rating, int stokAwal, String tanggalKedaluwarsa) {
        // Memanggil constructor dari class induk (Product) dan otomatis mengisi kategori dengan "Makanan"
        super(id, namaProduk, harga, "Makanan", rating, stokAwal);
        this.tanggalKedaluwarsa = tanggalKedaluwarsa;
    }

    // Getter dan Setter khusus untuk atribut Makanan
    public String getTanggalKedaluwarsa() {
        return tanggalKedaluwarsa;
    }

    public void setTanggalKedaluwarsa(String tanggalKedaluwarsa) {
        this.tanggalKedaluwarsa = tanggalKedaluwarsa;
    }
}
