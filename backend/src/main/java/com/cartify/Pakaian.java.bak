package com.cartify;

/**
 *
 * @author HP
 */
public class Pakaian extends Product {
    private String ukuran; // Contoh: S, M, L, XL

    // Constructor khusus untuk Pakaian
    public Pakaian(String id, String namaProduk, double harga, double rating, int stokAwal, String ukuran) {
        // Memanggil constructor dari class induk (Product) dan otomatis mengisi kategori dengan "Pakaian"
        super(id, namaProduk, harga, "Pakaian", rating, stokAwal);
        this.ukuran = ukuran;
    }

    // Getter dan Setter khusus untuk atribut Pakaian
    public String getUkuran() {
        return ukuran;
    }

    public void setUkuran(String ukuran) {
        this.ukuran = ukuran;
    }  
}
